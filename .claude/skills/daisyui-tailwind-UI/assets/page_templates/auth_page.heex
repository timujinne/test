<%!-- Authentication Page Template
     A clean and modern authentication page with sign-in form.
     Can be easily adapted for sign-up, password reset, etc.
--%>

<div class="min-h-screen bg-base-200 flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <%!-- Logo/Brand Section --%>
    <div class="text-center mb-8">
      <h1 class="text-4xl font-bold text-primary">MyApp</h1>
      <p class="text-base-content/60 mt-2">Welcome back! Please sign in to continue</p>
    </div>

    <%!-- Sign In Card --%>
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h2 class="card-title justify-center text-2xl mb-4">Sign In</h2>

        <%!-- Sign In Form --%>
        <form>
          <%!-- Email Input --%>
          <div class="form-control">
            <label class="label">
              <span class="label-text">Email</span>
            </label>
            <input
              type="email"
              name="email"
              placeholder="email@example.com"
              class="input input-bordered"
              required
            />
          </div>

          <%!-- Password Input --%>
          <div class="form-control mt-4">
            <label class="label">
              <span class="label-text">Password</span>
              <a href="#" class="label-text-alt link link-hover text-primary">
                Forgot password?
              </a>
            </label>
            <input
              type="password"
              name="password"
              placeholder="Enter your password"
              class="input input-bordered"
              required
            />
          </div>

          <%!-- Remember Me Checkbox --%>
          <div class="form-control mt-4">
            <label class="label cursor-pointer justify-start gap-4">
              <input type="checkbox" class="checkbox checkbox-primary" />
              <span class="label-text">Remember me</span>
            </label>
          </div>

          <%!-- Submit Button --%>
          <div class="form-control mt-6">
            <button type="submit" class="btn btn-primary">Sign In</button>
          </div>
        </form>

        <div class="divider">OR</div>

        <%!-- Social Sign In Buttons --%>
        <div class="space-y-2">
          <button class="btn btn-outline w-full gap-2">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
              <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continue with Google
          </button>

          <button class="btn btn-outline w-full gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Continue with GitHub
          </button>
        </div>

        <%!-- Sign Up Link --%>
        <div class="text-center mt-6">
          <p class="text-base-content/60">
            Don't have an account?
            <a href="#" class="link link-primary font-semibold">Sign up</a>
          </p>
        </div>
      </div>
    </div>

    <%!-- Footer Links --%>
    <div class="text-center mt-6 text-base-content/60 text-sm">
      <a href="#" class="link link-hover">Privacy Policy</a>
      <span class="mx-2">•</span>
      <a href="#" class="link link-hover">Terms of Service</a>
    </div>
  </div>
</div>

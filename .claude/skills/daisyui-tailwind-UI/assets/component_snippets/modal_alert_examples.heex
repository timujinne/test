<%!-- Modal and Alert Component Examples
     Common modal dialogs and alert patterns.
--%>

<%!-- Basic Modal with Checkbox Toggle --%>
<div>
  <%!-- Trigger button --%>
  <label for="basic-modal" class="btn btn-primary">Open Modal</label>

  <%!-- Modal --%>
  <input type="checkbox" id="basic-modal" class="modal-toggle" />
  <div class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">Modal Title</h3>
      <p class="py-4">This is the modal content. Click the button below to close.</p>
      <div class="modal-action">
        <label for="basic-modal" class="btn">Close</label>
      </div>
    </div>
  </div>
</div>

<%!-- Modal with Backdrop Close --%>
<div>
  <label for="backdrop-modal" class="btn">Open Modal</label>

  <input type="checkbox" id="backdrop-modal" class="modal-toggle" />
  <label for="backdrop-modal" class="modal cursor-pointer">
    <label class="modal-box relative" for="">
      <label for="backdrop-modal" class="btn btn-sm btn-circle absolute right-2 top-2">✕</label>
      <h3 class="text-lg font-bold">Modal with backdrop close</h3>
      <p class="py-4">Click outside this box or the X button to close</p>
    </label>
  </label>
</div>

<%!-- Confirmation Dialog Modal --%>
<div>
  <label for="confirm-modal" class="btn btn-error">Delete Item</label>

  <input type="checkbox" id="confirm-modal" class="modal-toggle" />
  <div class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">Confirm Deletion</h3>
      <p class="py-4">Are you sure you want to delete this item? This action cannot be undone.</p>
      <div class="modal-action">
        <label for="confirm-modal" class="btn">Cancel</label>
        <label for="confirm-modal" class="btn btn-error">Delete</label>
      </div>
    </div>
  </div>
</div>

<%!-- Alert Types --%>
<div class="space-y-4">
  <%!-- Info Alert --%>
  <div class="alert alert-info">
    <svg class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span>New software update available!</span>
  </div>

  <%!-- Success Alert --%>
  <div class="alert alert-success">
    <svg class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span>Your purchase has been confirmed!</span>
  </div>

  <%!-- Warning Alert --%>
  <div class="alert alert-warning">
    <svg class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
    </svg>
    <span>Warning: Your session will expire soon!</span>
  </div>

  <%!-- Error Alert --%>
  <div class="alert alert-error">
    <svg class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <span>Error! Task failed successfully.</span>
  </div>
</div>

<%!-- Alert with Action Buttons --%>
<div class="alert alert-warning shadow-lg">
  <svg class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
  </svg>
  <span>You have unsaved changes</span>
  <div>
    <button class="btn btn-sm">Discard</button>
    <button class="btn btn-sm btn-primary">Save</button>
  </div>
</div>

<%!-- Toast Notifications (Positioned) --%>
<div class="toast toast-top toast-end">
  <div class="alert alert-info">
    <span>New message received</span>
  </div>
</div>

<div class="toast toast-bottom toast-start">
  <div class="alert alert-success">
    <span>File uploaded successfully</span>
  </div>
</div>

<%!-- Toast with Multiple Alerts --%>
<div class="toast toast-top toast-center">
  <div class="alert alert-info">
    <span>Notification 1</span>
  </div>
  <div class="alert alert-success">
    <span>Notification 2</span>
  </div>
</div>

<%!-- Loading Modal --%>
<div>
  <input type="checkbox" id="loading-modal" class="modal-toggle" checked />
  <div class="modal">
    <div class="modal-box text-center">
      <span class="loading loading-spinner loading-lg"></span>
      <p class="mt-4">Processing your request...</p>
    </div>
  </div>
</div>

<%!-- Form in Modal --%>
<div>
  <label for="form-modal" class="btn btn-primary">Add New Item</label>

  <input type="checkbox" id="form-modal" class="modal-toggle" />
  <div class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg mb-4">Add New Item</h3>

      <form>
        <div class="form-control">
          <label class="label">
            <span class="label-text">Item Name</span>
          </label>
          <input type="text" placeholder="Enter name" class="input input-bordered" />
        </div>

        <div class="form-control mt-4">
          <label class="label">
            <span class="label-text">Description</span>
          </label>
          <textarea class="textarea textarea-bordered" placeholder="Enter description"></textarea>
        </div>

        <div class="modal-action">
          <label for="form-modal" class="btn">Cancel</label>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%!-- Alert with Close Button --%>
<div class="alert shadow-lg">
  <svg class="stroke-current shrink-0 w-6 h-6" fill="none" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
  </svg>
  <div>
    <h3 class="font-bold">New Update Available!</h3>
    <div class="text-xs">Version 2.0 is now available with new features</div>
  </div>
  <button class="btn btn-sm">Update Now</button>
  <button class="btn btn-sm btn-ghost">✕</button>
</div>

<%!-- Progress Modal --%>
<div>
  <input type="checkbox" id="progress-modal" class="modal-toggle" checked />
  <div class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">Uploading Files</h3>
      <p class="py-2">Please wait while we process your files...</p>
      <progress class="progress progress-primary w-full" value="70" max="100"></progress>
      <p class="text-sm text-center mt-2">70% Complete</p>
    </div>
  </div>
</div>

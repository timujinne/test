# ============================================
# Конфигурация для Elixir/Phoenix проекта
# ============================================
# ВАЖНО: Скопируйте этот файл в .env и измените значения!
# cp .env.example .env

# ============================================
# Общие настройки проекта
# ============================================
PROJECT_NAME=my_elixir_app
PROJECT_PATH=./my_elixir_app
MIX_ENV=dev

# ============================================
# PostgreSQL настройки
# ============================================
# Root пароль PostgreSQL (для администрирования)
POSTGRES_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD_123!

# Порт PostgreSQL (чтобы не конфликтовать с другими БД)
POSTGRES_PORT=5433

# База данных приложения
APP_DB_NAME=my_app_production
APP_DB_USER=my_app_user
APP_DB_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD_456!

# ============================================
# Phoenix настройки
# ============================================
PHOENIX_PORT=4000
PHX_HOST=localhost

# Сгенерируйте командой: mix phx.gen.secret
# Или: openssl rand -base64 48
SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_mix_phx_gen_secret_OR_openssl_rand_base64_48

# ============================================
# Cloak (шифрование данных в БД)
# ============================================
# Сгенерируйте командой: dd if=/dev/urandom bs=32 count=1 2>/dev/null | base64
CLOAK_KEY=CHANGE_ME_GENERATE_WITH_dd_command

# ============================================
# Redis (опционально)
# ============================================
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_789!

# ============================================
# Binance API (если используется)
# ============================================
# Для разработки используйте testnet!
# Получите на: https://testnet.binance.vision/
BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_SECRET_KEY=your_binance_testnet_secret_key
BINANCE_BASE_URL=https://testnet.binance.vision

# Для production (закомментировано):
# BINANCE_BASE_URL=https://api.binance.com

# ============================================
# SSH ключи (для git)
# ============================================
# Путь к вашим SSH ключам (будут доступны в контейнере read-only)
SSH_PATH=~/.ssh

# ============================================
# Livebook (опционально)
# ============================================
LIVEBOOK_PORT=8080

# ============================================
# БЕЗОПАСНОСТЬ - КОНТРОЛЬНЫЙ СПИСОК:
# ============================================
# ✓ Измените ВСЕ пароли на сильные (минимум 16 символов)
# ✓ НЕ коммитьте .env файл в git!
# ✓ Добавьте .env в .gitignore
# ✓ Используйте testnet для разработки
# ✓ Регулярно ротируйте API ключи и пароли
# ✓ В production используйте SSL для PostgreSQL
# ✓ В production используйте секреты менеджеры (vault, aws secrets manager)
# ✓ Ограничьте доступ к портам через firewall
# ============================================
